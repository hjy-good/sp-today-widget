<?xml version="1.0" encoding="utf-8"?>
<!--
  One weekly load bar row: [day_label]  [progress bar]  [load text]
  Rendered by ScheduleWidgetViewsFactory for each day in the 7-day window.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/day_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <TextView
        android:id="@+id/day_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="20dp"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:text="·" />

    <ProgressBar
        android:id="@+id/day_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/day_load_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="46dp"
        android:gravity="end"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:text="" />
</LinearLayout>
