<?xml version="1.0" encoding="utf-8"?>
<!--
  Schedule widget root layout. Top section: up to 4 tomorrow events, inlined
  directly (RemoteViews doesn't allow re-using <include> with distinct inner
  ids, so rows are duplicated with row-specific ids).
  Bottom section: scrollable weekly load bar list served by a RemoteViewsFactory.

  IMPORTANT: Samsung One UI / LockStar ignores root-level padding on RemoteViews
  lockscreen renders. Use layout_marginStart/End on each child instead.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/schedule_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/schedule_tomorrow_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="@string/schedule_tomorrow_placeholder" />

    <TextView
        android:id="@+id/schedule_tomorrow_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="6dp"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        android:visibility="gone"
        android:text="@string/schedule_tomorrow_empty" />

    <!-- Tomorrow event row 1 -->
    <LinearLayout
        android:id="@+id/tomorrow_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tomorrow_time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:text="--:--" />
        <TextView
            android:id="@+id/tomorrow_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />
        <TextView
            android:id="@+id/tomorrow_duration_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:text="" />
    </LinearLayout>

    <!-- Tomorrow event row 2 -->
    <LinearLayout
        android:id="@+id/tomorrow_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tomorrow_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:text="--:--" />
        <TextView
            android:id="@+id/tomorrow_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />
        <TextView
            android:id="@+id/tomorrow_duration_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:text="" />
    </LinearLayout>

    <!-- Tomorrow event row 3 -->
    <LinearLayout
        android:id="@+id/tomorrow_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tomorrow_time_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:text="--:--" />
        <TextView
            android:id="@+id/tomorrow_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />
        <TextView
            android:id="@+id/tomorrow_duration_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:text="" />
    </LinearLayout>

    <!-- Tomorrow event row 4 -->
    <LinearLayout
        android:id="@+id/tomorrow_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/tomorrow_time_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:text="--:--" />
        <TextView
            android:id="@+id/tomorrow_title_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />
        <TextView
            android:id="@+id/tomorrow_duration_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:text="" />
    </LinearLayout>

    <!--
      Divider: RemoteViews doesn't allow plain <View>, so use ImageView
      (whitelisted) with a background color as a 1dp horizontal rule.
    -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="#33FFFFFF"
        android:contentDescription="@null" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="4dp"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:text="@string/schedule_week_load_header" />

    <ListView
        android:id="@+id/schedule_week_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp" />
</LinearLayout>
